# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env real a GitHub (ya está en .gitignore).

# Token de la API de ESIOS (Red Eléctrica de España)
# Consíguelo en https://www.esios.ree.es/es
ESIOS_TOKEN=tu_token_aqui

# Conexión a PostgreSQL (coincide con docker-compose.yml)
DATABASE_URL=postgresql://clima_user:clima_pass@localhost:5432/clima_energia
